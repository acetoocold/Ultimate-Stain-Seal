# Database Connection
# PostgreSQL connection string for local development
# Example: postgresql://postgres:password@localhost:5432/uss_dev
DATABASE_URL=postgresql://postgres:password@localhost:5432/uss_dev

# Node Environment
NODE_ENV=development

# API Server
API_PORT=8080
API_HOST=localhost

# Frontend
FRONTEND_PORT=5173
FRONTEND_HOST=0.0.0.0

# Optional: Base path for frontend routing (default: "/")
BASE_PATH=/

# Optional: Port mapping (only needed if using non-standard ports)
PORT=5173
